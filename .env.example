ENVIRONMENT=development
MONGO_URI=mongodb://localhost:27017/rag_brain
MONGO_DB_NAME=rag_brain

JWT_SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI agents, hosted tracing, legacy Q&A, and optional OpenAI embeddings
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.4-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_QNA_MODEL=gpt-5.4-mini
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=false

# Document ingestion and retrieval embeddings
LLAMA_COLLECTION_NAME=qa_collection
LLAMA_EMBED_PROVIDER=huggingface
LLAMA_EMBED_MODEL=VoVanPhuc/sup-SimCSE-VietNamese-phobert-base
HF_HOME=./hf_cache

STORAGE_ROOT=
RAILWAY_VOLUME_MOUNT_PATH=
LLAMA_CHROMA_PERSIST_DIR=
BM25_PERSIST_DIR=
DOCSTORE_PERSIST_DIR=
TEMP_KB_DIR=tmp/knowledge_base
ALLOW_KB_TARGET_USER_UPLOAD=false
LOAN_UPLOAD_DIR=

RAG_BRAIN_OPENCLAW_API_KEY=

# Shared specialist-agent FastMCP adapter
# RAG_MCP_USER_ID is a legacy fallback for Credit only.
RAG_MCP_USER_ID=
RAG_MCP_CREDIT_USER_ID=
RAG_MCP_COMPLIANCE_USER_ID=
RAG_MCP_OPERATIONS_USER_ID=
LOAN_DATA_MCP_USER_ID=

# Agent-side MCP endpoint
RAG_MCP_URL=http://127.0.0.1:8766/mcp

# MCP server bind address
RAG_MCP_HOST=127.0.0.1
RAG_MCP_PORT=8766
